---
import MenubarsIcon from "../icons/MenubarsIcon.astro";
---
<div class="max-w-full">
  <nav class="relative z-50 mb-3 border-b-2 border-minsk-600 bg-minsk-800 px-2 text-white drop-shadow-2xl">
    <div class="container mx-auto flex items-center justify-between px-4 py-3">
      <a
        class="inline-block whitespace-nowrap text-xl font-bold uppercase leading-relaxed text-white drop-shadow-sm hover:opacity-75"
        href="/"
      >
        Jouni Lammi
      </a>

      <div class="relative" data-nav-root>
        <button
          type="button"
          class="inline-flex items-center gap-2 rounded-lg border border-minsk-500 bg-minsk-700 px-3 py-2 text-sm font-medium text-white transition hover:bg-minsk-600"
          aria-expanded="false"
          aria-controls="site-menu"
          data-nav-toggle
        >
          <MenubarsIcon color="text-white" />
          <span>Menu</span>
        </button>

        <div
          id="site-menu"
          data-nav-menu
          class="absolute right-0 top-[calc(100%+0.75rem)] z-50 hidden min-w-[16rem] rounded-xl border border-minsk-600 bg-minsk-900 p-2 shadow-2xl shadow-minsk-950/50"
        >
          <details class="group rounded-lg" data-tools-menu open>
            <summary class="cursor-pointer list-none rounded-lg px-3 py-2 text-sm font-medium text-stone-100 transition hover:bg-minsk-800">
              <span class="flex items-center justify-between gap-4">
                <span>Tools</span>
                <span class="text-stone-400 transition group-open:rotate-90">›</span>
              </span>
            </summary>

            <div class="mt-1 rounded-lg bg-minsk-950/40 p-1">
              <a
                href="/qr"
                class="block rounded-md px-3 py-2 text-sm text-stone-100 transition hover:bg-minsk-800"
              >
                QR code generator
              </a>
            </div>
          </details>
        </div>
      </div>
    </div>
  </nav>
</div>

<script>
  const navRoot = document.querySelector('[data-nav-root]');
  const navToggle = document.querySelector('[data-nav-toggle]');
  const navMenu = document.querySelector('[data-nav-menu]');

  if (
    !(navRoot instanceof HTMLElement) ||
    !(navToggle instanceof HTMLButtonElement) ||
    !(navMenu instanceof HTMLElement)
  ) {
    throw new Error('Navbar elements were not found.');
  }

  const closeMenu = () => {
    navMenu.classList.add('hidden');
    navToggle.setAttribute('aria-expanded', 'false');
  };

  navToggle.addEventListener('click', () => {
    const isOpen = !navMenu.classList.contains('hidden');
    navMenu.classList.toggle('hidden', isOpen);
    navToggle.setAttribute('aria-expanded', String(!isOpen));
  });

  document.addEventListener('click', (event) => {
    if (!(event.target instanceof Node) || navRoot.contains(event.target)) {
      return;
    }

    closeMenu();
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      closeMenu();
    }
  });
</script>
